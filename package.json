{
    "name": "@repo/source",
    "version": "2.0.1",
    "license": "MIT",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "githook": "pnpx lefthook install",
        "f1": "pnpm biome format . --write --diagnostic-level=error --no-errors-on-unmatched --files-ignore-unknown=true",
        "f2": "nx format:write --all",
        "f": "pnpm run f1 && pnpm run f2",
        "format": "pnpm run f1 && pnpm run f2",
        "lint": "pnpm biome lint . --skip=suspicious/noExplicitAny",
        "dev": "nx serve",
        "web": "nx serve web",
        "mobile": "nx serve mobile",
        "admin": "nx serve admin",
        "server": "nx run server:serve",
        "server:build": "nx build server",
        "db:up": "cd apps/server && npx drizzle-kit up",
        "db:c1": "pnpm drizzle-kit generate --config=apps/server/drizzle.config.ts",
        "db:check": "cd apps/server && npx drizzle-kit check",
        "db:generate": "cd apps/server && npx drizzle-kit generate",
        "db:migrate": "cd apps/server && npx drizzle-kit migrate",
        "db:push": "cd apps/server && npx drizzle-kit push",
        "db:local-dev": "cd apps/server && npx drizzle-kit push",
        "db:studio": "cd apps/server && npx drizzle-kit studio",
        "db:generate-erd": "drizzle-erd --in ./apps/server/src/core/db/schema.ts --out ./apps/server/erd.svg",
        "db:dbml": "tsx ./apps/server/dbml.ts",
        "update1of3": "nx migrate latest --verbose",
        "update2of3": "nx migrate --run-migrations --if-exists",
        "update3of3": "rm migrations.json",
        "run:remove-spec-files": "find . -type f -name '*.spec.ts' -exec rm {} +",
        "prebuild:ios": "rm -f dist/apps/web/browser/assets/gp.* || true",
        "build:ios": "nx build web --configuration=ios && npm run prebuild:ios",
        "report": "nx report"
    },
    "private": true,
