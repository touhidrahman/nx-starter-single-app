})

const Get{{pascalCase moduleName}}: AppRouteHandler<typeof Get{{pascalCase moduleName}}Def> = async (c) => {
    const { groupId } = c.get('jwtPayload') as AccessTokenPayload
    const id = c.req.valid('param').id

    if (!groupId) {
        throw new HTTPException(NOT_FOUND, { message: '{{pascalCase moduleName}} not found' })
    }

    const existing = await {{pascalCase moduleName}}Service.findByIdAndGroupId(id, groupId)
    if (!existing) {
        throw new HTTPException(NOT_FOUND, { message: '{{pascalCase moduleName}} not found' })
    }

    return c.json(
        {
            data: existing,
            message: '{{pascalCase moduleName}} fetched successfully',
            success: true,
        },
        OK,
    )
}

const Create{{pascalCase moduleName}}Def = createRoute({
