const Create{{pascalCase moduleName}}: AppRouteHandler<typeof Create{{pascalCase moduleName}}Def> = async (
    c,
) => {
    const { groupId, sub: creatorId } = c.get(
        'jwtPayload',
    ) as AccessTokenPayload
    const input = c.req.valid('json')

    if (!groupId) {
        throw new HTTPException(FORBIDDEN, {
            message: '{{pascalCase moduleName}} could not be created',
        })
    }

    const data = await {{pascalCase moduleName}}Service.create({
        ...input,
        groupId,
        creatorId,
    })

    return c.json(
        {
            data,
            message: '{{pascalCase moduleName}} created successfully',
            success: true,
        },
        OK,
    )
}

