const tags = ['{{pascalCase moduleName}}']
const path = '/{{kebabCase (pluralize moduleName)}}'

const Get{{pascalCase moduleName}}ListDef = createRoute({
    path: path,
    tags,
    method: 'get',
    middleware: [checkToken, checkPermission(['{{pascalCase moduleName}}:Read'])] as const,
    request: {
        query: zQuery{{pascalCase (pluralize moduleName)}},
    },
    responses: {
        [OK]: ApiListResponse(z.array(zSelect{{pascalCase moduleName}}), '{{pascalCase moduleName}} List'),
    },
})

const Get{{pascalCase moduleName}}List: AppRouteHandler<
    typeof Get{{pascalCase moduleName}}ListDef
> = async (c) => {
    const query = c.req.valid('query')
    const { groupId } = c.get('jwtPayload') as AccessTokenPayload
    const groupSpecificQuery = { ...query, groupId }
    const data = await {{pascalCase moduleName}}Service.findMany(groupSpecificQuery)
    const count = await {{pascalCase moduleName}}Service.count(groupSpecificQuery)

    return c.json(
        {
            data,
            pagination: buildPaginationResponse(query.page, query.size, count),
            message: '{{pascalCase moduleName}} list fetched successfully',
            success: true,
        },
        OK,
    )
}

const Get{{pascalCase moduleName}}Def = createRoute({
    path: `${path}/:id`,
    tags,
    method: 'get',
    middleware: [checkToken, checkPermission(['{{pascalCase moduleName}}:Read'])] as const,
    request: {
        params: zId,
    },
    responses: {
        [OK]: ApiResponse(zSelect{{pascalCase moduleName}}, 'Item'),
